---
import { portfolio, type Lang } from '../data/portfolio';
interface Props { lang?: Lang; }
const lang = Astro.props.lang ?? 'es';
const content = portfolio[lang];
const { ui } = content;
---
<section id="especialidades" class="section">
  <div class="shell">
    <p class="eyebrow">{ui.sections.specialtiesEyebrow}</p>
    <h2 class="section-title">{ui.sections.specialtiesTitle}</h2>
    <div class="mt-12 grid gap-4 md:grid-cols-2">
      {content.specialties.map((item) => <article class="glass card-hover group rounded-2xl p-6 sm:p-8">
        <div class="flex items-start justify-between"><span class="font-mono text-xs text-slate-600">{item.number}</span><span class="rounded-lg border border-electric/20 bg-electric/5 px-3 py-2 font-mono text-[.65rem] text-electric">{item.icon}</span></div>
        <h3 class="mt-10 text-xl font-semibold tracking-tight group-hover:text-electric">{item.title}</h3><p class="mt-3 max-w-md text-sm leading-7 text-slate-400">{item.description}</p>
      </article>)}
    </div>
  </div>
</section>
<section id="habilidades" class="section border-y border-white/[.055] bg-white/[.015]">
  <div class="shell">
    <p class="eyebrow">{ui.sections.skillsEyebrow}</p><h2 class="section-title">{ui.sections.skillsTitle}</h2>
    <div class="mt-12 grid gap-4 lg:grid-cols-2">
      {content.skills.map((group, index) => <article class="rounded-2xl border border-white/10 bg-ink/40 p-6 sm:p-7">
        <div class="flex gap-4"><span class="font-mono text-xs text-electric">0{index + 1}</span><h3 class="font-semibold">{group.category}</h3></div>
        <div class="mt-6 flex flex-wrap gap-2">{group.items.map((skill) => <span class="rounded-full border border-white/9 bg-white/[.025] px-3 py-2 text-xs text-slate-400">{skill}</span>)}</div>
      </article>)}
    </div>
  </div>
</section>
