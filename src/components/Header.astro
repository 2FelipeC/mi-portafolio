---
import { navigation, portfolio, type Lang } from '../data/portfolio';
interface Props { lang?: Lang; }
const lang = Astro.props.lang ?? 'es';
const content = portfolio[lang];
const navItems = navigation[lang];
const { ui } = content;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const emailHref = `https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(content.person.email)}&su=${encodeURIComponent(ui.emailSubject)}`;
---
<header class="fixed inset-x-0 top-0 z-50 border-b border-white/8 bg-ink/78 backdrop-blur-xl">
  <div class="shell flex h-[4.75rem] items-center justify-between">
    <a href="#inicio" class="focus-ring flex items-center gap-3 rounded-lg" aria-label={ui.homeAria}>
      <span class="grid size-12 shrink-0 place-items-center">
        <img src={`${basePath}/LOGO2FC2.webp`} alt="" class="size-12 object-contain" loading="eager" decoding="async" />
      </span>
      <span class="hidden text-sm font-semibold tracking-tight sm:block">{content.person.displayName}</span>
    </a>
    <nav class="hidden items-center gap-5 lg:flex" aria-label={ui.navLabel}>
      {navItems.map(([label, href]) => <a class="focus-ring rounded text-[.76rem] text-slate-400 transition hover:text-white" href={href}>{label}</a>)}
    </nav>
    <div class="flex items-center gap-3">
      <a href={ui.otherLocaleHref} class="focus-ring grid size-10 place-items-center rounded-xl border border-white/10 bg-white/[.035] font-mono text-[.68rem] font-bold text-slate-300 transition hover:border-electric/30 hover:text-electric" aria-label={`Switch language to ${ui.otherLocaleName}`}>{ui.otherLocaleName}</a>
      <button id="theme-toggle" class="focus-ring grid size-10 place-items-center rounded-xl border border-white/10 bg-white/[.035] font-mono text-xs text-slate-300 transition hover:border-electric/30 hover:text-electric" type="button" aria-label={ui.themeLight} title="Cambiar tema" data-light-label={ui.themeLight} data-dark-label={ui.themeDark}>
        <span id="theme-icon" aria-hidden="true">☾</span>
      </button>
      <a href={emailHref} target="_blank" rel="noreferrer" class="focus-ring hidden rounded-full border border-electric/25 bg-electric/8 px-4 py-2 text-xs font-semibold text-electric transition hover:bg-electric/15 sm:block">{ui.talk}</a>
      <button id="menu-toggle" class="focus-ring grid size-10 place-items-center rounded-xl border border-white/10 lg:hidden" aria-label={ui.menuAria} aria-expanded="false" aria-controls="mobile-menu">
        <span class="flex w-4 flex-col gap-1.5"><i class="h-px w-full bg-white"></i><i class="h-px w-full bg-white"></i></span>
      </button>
    </div>
  </div>
  <nav id="mobile-menu" class="shell hidden border-t border-white/8 py-4 lg:hidden" aria-label={ui.mobileNavLabel}>
    <div class="grid grid-cols-2 gap-1">
      {navItems.map(([label, href]) => <a class="rounded-lg px-3 py-2.5 text-sm text-slate-300 hover:bg-white/5" href={href}>{label}</a>)}
    </div>
  </nav>
</header>
<script>
  const button = document.querySelector<HTMLButtonElement>('#menu-toggle');
  const menu = document.querySelector<HTMLElement>('#mobile-menu');
  const themeButton = document.querySelector<HTMLButtonElement>('#theme-toggle');
  const themeIcon = document.querySelector<HTMLElement>('#theme-icon');
  const systemDark = window.matchMedia('(prefers-color-scheme: dark)');
  const storedTheme = () => {
    try { return localStorage.getItem('theme'); } catch { return null; }
  };
  const currentTheme = () => document.documentElement.dataset.theme || (systemDark.matches ? 'dark' : 'light');
  const paintThemeButton = () => {
    const theme = currentTheme();
    if (themeIcon) themeIcon.textContent = theme === 'dark' ? '☾' : '☀';
    themeButton?.setAttribute('aria-label', theme === 'dark' ? (themeButton.dataset.lightLabel || 'Switch to light mode') : (themeButton.dataset.darkLabel || 'Switch to dark mode'));
  };
  const setTheme = (theme: 'light' | 'dark') => {
    document.documentElement.dataset.theme = theme;
    try { localStorage.setItem('theme', theme); } catch {}
    paintThemeButton();
  };
  const close = () => { menu?.classList.add('hidden'); button?.setAttribute('aria-expanded', 'false'); };
  button?.addEventListener('click', () => { const open = button.getAttribute('aria-expanded') === 'true'; menu?.classList.toggle('hidden', open); button.setAttribute('aria-expanded', String(!open)); });
  themeButton?.addEventListener('click', () => setTheme(currentTheme() === 'dark' ? 'light' : 'dark'));
  systemDark.addEventListener('change', () => { if (!storedTheme()) paintThemeButton(); });
  menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', close));
  paintThemeButton();
</script>
