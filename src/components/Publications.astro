---
import { portfolio, type Lang } from '../data/portfolio';
interface Props { lang?: Lang; }
const lang = Astro.props.lang ?? 'es';
const content = portfolio[lang];
const { ui } = content;
const software = content.intellectualProperty[0];
---
<section id="publicaciones" class="section border-y border-white/[.055] bg-white/[.015]">
  <div class="shell">
    <p class="eyebrow">{ui.sections.ipEyebrow}</p><h2 class="section-title">{ui.sections.ipTitle}</h2>
    <article class="mt-12 overflow-hidden rounded-3xl border border-electric/25 bg-gradient-to-br from-electric/10 via-panel/80 to-violet/10 p-7 sm:p-10">
      <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-3xl">
          <span class="inline-flex rounded-full border border-electric/25 bg-electric/10 px-3 py-1.5 font-mono text-[.65rem] uppercase tracking-wider text-electric">{ui.sections.ipBadge}</span>
          <h3 class="mt-6 text-2xl font-semibold tracking-tight sm:text-3xl">{software.title}</h3>
          <div class="mt-5 space-y-4">
            {software.description.split('\n\n').map((paragraph) => <p class="text-sm leading-7 text-slate-400">{paragraph}</p>)}
          </div>
          <p class="mt-6 text-sm leading-7 text-slate-400"><strong class="text-slate-300">{ui.roleLabel}</strong> {software.role}</p>
          <div class="mt-5 space-y-2 text-sm text-slate-400">
            <p><strong class="text-slate-300">{software.registrationLabel}:</strong> {software.venue}</p>
            <p><strong class="text-slate-300">{software.authorsLabel}:</strong> {software.authors}</p>
          </div>
        </div>
        <time class="font-mono text-xs text-electric">{software.date}</time>
      </div>
      <div class="mt-8 flex flex-wrap gap-2">{software.tags.map((tag) => <span class="rounded-full border border-white/10 bg-ink/30 px-3 py-2 font-mono text-[.64rem] text-slate-400">{tag}</span>)}</div>
    </article>
    <div class="mt-12 flex items-center gap-4"><h3 class="font-mono text-xs uppercase tracking-[.16em] text-slate-500">{ui.sections.relatedPublications}</h3><span class="h-px flex-1 bg-white/10"></span></div>
    <div class="mt-5 grid gap-4">{content.publications.map((item, i) => <article class="glass card-hover grid gap-6 rounded-2xl p-6 md:grid-cols-[80px_1fr_auto] md:items-start md:p-8"><span class="font-mono text-xs text-slate-600">PUB.{String(i + 1).padStart(2, '0')}</span><div><span class="font-mono text-[.65rem] uppercase tracking-wider text-electric">{item.type}</span><h3 class="mt-3 max-w-3xl text-lg font-semibold leading-7">{item.title}</h3><p class="mt-4 text-xs leading-6 text-slate-500">{item.authors}</p><p class="mt-2 text-sm text-slate-400">{item.venue}</p></div><time class="font-mono text-xs text-slate-500">{item.date}</time></article>)}</div>
  </div>
</section>
