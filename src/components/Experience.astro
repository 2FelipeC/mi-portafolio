---
import { portfolio, type Lang } from '../data/portfolio';
interface Props { lang?: Lang; }
const lang = Astro.props.lang ?? 'es';
const content = portfolio[lang];
const { ui } = content;
---
<section id="experiencia" class="section border-y border-white/[.055] bg-white/[.015]">
  <div class="shell">
    <p class="eyebrow">{ui.sections.experienceEyebrow}</p><h2 class="section-title">{ui.sections.experienceTitle}</h2>
    <div class="mt-14">
      {content.experience.map((item, i) => <article class="grid gap-5 border-t border-white/10 py-9 md:grid-cols-[180px_1fr] md:gap-10">
        <div><span class="font-mono text-xs text-electric">{item.date}</span><span class="mt-3 block font-mono text-[.65rem] text-slate-600">EXP.0{i + 1}</span></div>
        <div>
          <div class="flex flex-wrap items-center gap-3"><h3 class="text-xl font-semibold">{item.role}</h3>{item.project && <span class="rounded-full border border-violet/20 bg-violet/7 px-3 py-1 font-mono text-[.62rem] text-violet">{item.project}</span>}</div>
          <p class="mt-2 text-sm text-slate-300">{item.organization}</p>
          <div class="mt-5 max-w-3xl space-y-4">
            {item.description.split('\n\n').map((paragraph) => <p class="text-sm leading-7 text-slate-400">{paragraph}</p>)}
          </div>
        </div>
      </article>)}
    </div>
    <h3 class="mt-14 font-mono text-xs uppercase tracking-[.18em] text-slate-500">{ui.sections.formativeTitle}</h3>
    <div class="mt-5 grid gap-4 md:grid-cols-2">{content.formativeExperience.map((item) => <article class="glass rounded-2xl p-6"><span class="font-mono text-[.68rem] text-electric">{item.date}</span><h4 class="mt-5 text-lg font-semibold">{item.role}</h4><p class="mt-1 text-sm text-slate-400">{item.organization} · {item.location}</p><div class="mt-5 space-y-4">{item.description.split('\n\n').map((paragraph) => <p class="text-sm leading-7 text-slate-500">{paragraph}</p>)}</div></article>)}</div>
  </div>
</section>
