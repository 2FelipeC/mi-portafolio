---
import { portfolio, type Lang } from '../data/portfolio';
interface Props { lang?: Lang; }
const lang = Astro.props.lang ?? 'es';
const content = portfolio[lang];
const { ui } = content;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section id="proyectos" class="section">
  <div class="shell">
    <p class="eyebrow">{ui.sections.projectsEyebrow}</p><h2 class="section-title">{ui.sections.projectsTitle}</h2>
    <div class="mt-12 space-y-5">
      {content.projects.map((project, index) => <article class="glass card-hover grid overflow-hidden rounded-3xl lg:grid-cols-[.8fr_1.2fr]">
        <div class="relative min-h-64 overflow-hidden border-b border-white/10 bg-panel p-7 lg:border-b-0 lg:border-r">
          <div class="absolute inset-0 opacity-25 [background-image:radial-gradient(var(--theme-accent)_1px,transparent_1px)] [background-size:20px_20px]"></div>
          <div class:list={["absolute rounded-full blur-3xl", index === 1 ? 'right-2 top-8 size-40 bg-violet/25' : 'bottom-6 left-8 size-44 bg-electric/20']}></div>
          <div class="relative flex h-full flex-col justify-between gap-10">
            <span class="font-mono text-xs text-slate-500">CASE_{String(index + 1).padStart(2, '0')}</span>
            <div class="grid min-h-[154px] place-items-center sm:min-h-[179px] lg:min-h-48">
              <img src={`${basePath}/${project.image.light}`} alt={project.image.alt} class="theme-project-image-light max-h-[154px] w-full max-w-[376px] object-contain sm:max-h-[179px] lg:max-h-[205px]" loading="lazy" decoding="async" />
              <img src={`${basePath}/${project.image.dark}`} alt="" class="theme-project-image-dark max-h-[154px] w-full max-w-[376px] object-contain sm:max-h-[179px] lg:max-h-[205px]" loading="lazy" decoding="async" />
            </div>
            <div><strong class="font-mono text-3xl text-electric">{project.code}</strong><p class="mt-2 font-mono text-[.65rem] uppercase tracking-widest text-slate-500">{project.type}</p></div>
          </div>
        </div>
        <div class="p-7 sm:p-9"><h3 class="text-2xl font-semibold tracking-tight sm:text-3xl">{project.title}</h3><p class="mt-5 text-sm leading-7 text-slate-400">{project.description}</p>{project.role && <p class="mt-4 text-sm leading-7 text-slate-500"><strong class="text-slate-300">{ui.roleLabel}</strong> {project.role}</p>}
          <div class="mt-6 flex flex-wrap gap-2">{project.technologies.map((tech) => <span class="font-mono text-[.65rem] text-electric/80">#{tech.replaceAll(' ', '_')}</span>)}</div>
          {project.links.length > 0 && <div class="mt-8 flex gap-5">{project.links.map((link) => link.temporary ? <span class="cursor-not-allowed text-xs text-slate-600" title={ui.pendingTitle}>{link.label} · {ui.pending}</span> : <a href={link.href} class="text-sm text-electric" target="_blank" rel="noreferrer">{link.label} ↗</a>)}</div>}
        </div>
      </article>)}
    </div>
  </div>
</section>
